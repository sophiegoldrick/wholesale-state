# ── Database (auto-filled by Railway) ──────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── App ─────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
DASHBOARD_PASSWORD=wholesale2026

# ── Microsoft Azure App Registration ───────────────────────────
# From Azure Portal → App registrations → your app
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── Graph OAuth redirect (must match Azure Portal exactly) ─────
# Format: https://YOUR-APP.railway.app/api/graph/callback
GRAPH_REDIRECT_URI=https://your-app.railway.app/api/graph/callback

# ── Optional ────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.railway.app
